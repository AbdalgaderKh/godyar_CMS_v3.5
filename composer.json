{
  "name": "godyar/cms",
  "type": "project",
  "require": {
    "php": ">=8.0"
  },
  "autoload": {
    "psr-4": {
      "Godyar\\": "includes/classes/",
      "App\\": "src/",
      "GodyarV4\\": "app/V4/"
    }
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.11",
    "vimeo/psalm": "^5.0",
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "lint": "php -l index.php",
    "cs": "php-cs-fixer fix --diff --ansi",
    "stan": "phpstan analyse --ansi",
    "psalm": "psalm --show-info=true",
    "test": "phpunit",
    "lint:all": "find . -name '*.php' -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
    "phpcs": "phpcs --standard=.phpcs.xml.dist",
    "phpstan": "phpstan analyse -c phpstan.neon.dist --ansi"
  },
  "description": "Godyar CMS - نظام إدارة محتوى للأخبار (News CMS)",
  "license": "MIT",
  "homepage": "https://example.com",
  "support": {
    "issues": "https://github.com/example/godyar-cms/issues",
    "email": "maintainer@example.com"
  },
  "keywords": [
    "cms",
    "news",
    "php",
    "godyar",
    "rtl",
    "multilingual"
  ]
}
